        "qual melhor anime",
        "assiste anime",
        "anime favorito",
        "gosta de naruto",
        "gosta de one piece",
        "gosta de vocaloid"
      ],
      "responses": [
        "Anime é muito legal ",
        "Existem muitos animes incríveis.",
        "Vocaloid tem músicas muito boas "
      ]
    },

    {
      "tag": "musica",
      "patterns": [
