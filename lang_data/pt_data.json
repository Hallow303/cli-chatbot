        "musica favorita"
      ],
      "responses": [
        "Música deixa qualquer conversa melhor ",
        "K-pop e Vocaloid são interessantes ",
        "Tenho gosto musical variado "
      ]
    },

    {
      "tag": "comida",
      "patterns": [
