{
  "intents": [
    {
      "tag": "saudacao",
      "patterns": [
        "oi",
        "olá",
        "opa",
        "eae",
        "bom dia",
        "boa tarde",
        "boa noite",
        "salve",
        "iae",
        "fala ai",
        "hey",
        "yo",
        "oii",
        "olaaa",
        "e ai tudo bem",
        "como vai",
        "fala",
        "opa tudo bom",
        "alo",
        "tem alguem ai"
      ],
      "responses": [
        "Olá ",
        "Oi!",
        "Eae!",
        "Salve ",
        "Olá, como posso ajudar?",
        "Hey!"
      ]
    },

    {
      "tag": "despedida",
      "patterns": [
        "tchau",
        "falou",
        "até mais",
        "ate logo",
        "fui",
        "bye",
        "vou embora",
        "tenho que ir",
        "até depois",
        "xau",
        "adeus",
        "nos vemos",
        "até amanhã",
        "vlw",
        "valeu"
      ],
      "responses": [
        "Até mais ",
        "Falou!",
        "Tchau!",
        "Nos vemos depois.",
        "Valeu pela conversa "
      ]
    },

    {
      "tag": "agradecimento",
      "patterns": [
        "obrigado",
        "valeu",
        "tmj",
        "muito obrigado",
        "thanks",
        "agradeço",
        "brigado",
        "vlw",
        "obg",
        "obrigadão",
        "grato"
      ],
      "responses": [
        "De nada ",
        "Tmj ",
        "Sempre que precisar!",
        "Disponha.",
        "Foi um prazer ajudar."
      ]
    },

    {
      "tag": "nome_bot",
      "patterns": [
        "qual seu nome",
        "quem é voce",
        "como voce se chama",
        "quem é vc",
        "seu nome",
        "como te chamam",
        "qual é seu nome",
        "você é quem"
      ],
      "responses": [
        "Sou um mini chatbot ",
        "Pode me chamar de Bot.",
        "Sou um chatbot feito em Python.",
        "Ainda não tenho um nome oficial "
      ]
    },

    {
      "tag": "idade_bot",
      "patterns": [
        "quantos anos voce tem",
        "qual sua idade",
        "idade",
        "voce nasceu quando",
        "você é velho",
        "tem quantos anos"
      ],
      "responses": [
        "Chatbots não envelhecem ",
        "Não tenho idade humana.",
        "Fui criado recentemente "
      ]
    },

    {
      "tag": "criador",
      "patterns": [
        "quem te criou",
        "quem fez voce",
        "quem é seu criador",
        "quem programou voce",
        "quem desenvolveu voce",
        "quem fez esse bot"
      ],
      "responses": [
        "Fui criado por um programador ",
        "Meu criador usou Python para me fazer.",
        "Sou resultado de muito café e código "
      ]
    },

    {
      "tag": "humor",
      "patterns": [
        "tudo bem",
        "como voce está",
        "como vai",
        "ta bem",
        "ta tudo certo",
        "como vc ta",
        "esta bem"
      ],
      "responses": [
        "Estou funcionando perfeitamente ",
        "Tudo certo por aqui!",
        "Pronto para conversar "
      ]
    },

    {
      "tag": "ajuda",
      "patterns": [
        "me ajuda",
        "preciso de ajuda",
        "pode ajudar",
        "socorro",
        "help",
        "como funciona",
        "o que voce faz",
        "o que vc sabe fazer"
      ],
      "responses": [
        "Posso responder perguntas simples ",
        "Ainda estou aprendendo novas coisas.",
        "Você pode conversar comigo usando texto."
      ]
    },

    {
      "tag": "programacao",
      "patterns": [
        "voce sabe programar",
        "python é bom",
        "o que acha de python",
        "gosta de programação",
        "me fale sobre codigo",
        "qual melhor linguagem",
        "java ou python",
        "c++ é dificil"
      ],
      "responses": [
        "Python é ótimo para iniciantes ",
        "Programação é muito divertida.",
        "Cada linguagem tem seus pontos fortes.",
        "Praticar projetos ajuda muito a aprender."
      ]
    },

    {
      "tag": "tempo",
      "patterns": [
        "como está o tempo",
        "vai chover",
        "esta calor",
        "clima",
        "temperatura",
        "ta frio",
        "como ta o clima"
      ],
      "responses": [
        "Não consigo ver o clima em tempo real ",
        "Talvez seja melhor olhar um app de previsão.",
        "Espero que esteja um clima agradável "
      ]
    },

    {
